# Gallery images are committed for README display
!docs/gallery/*.png

# Tool-specific local agent/skill install directories
.agents/
.codex/
AGENTS.md
skills/

# Allow .claude/skills/ (main skill package)
!.claude/
!.claude/skills/
!.claude/skills/**

# Re-ignore Python bytecode under skills (the broad !.claude/skills/**
# above would otherwise unignore __pycache__/ directories — and Python's
# import machinery regenerates these on every run, polluting git status).
.claude/skills/**/__pycache__/
.claude/skills/**/*.py[cod]

# Bundled font payloads — user-supplied, NEVER commit
# Most journal-anchor typefaces (Arial, Helvetica, Times New Roman, SimHei) are
# commercial fonts that cannot be legally redistributed; keep them out of the
# repository even when dropped into the skill's assets/fonts/ directory.
.claude/skills/*/assets/fonts/*.ttf
.claude/skills/*/assets/fonts/*.otf
.claude/skills/*/assets/fonts/*.ttc
.claude/skills/*/assets/fonts/*.TTF
.claude/skills/*/assets/fonts/*.OTF
.claude/skills/*/assets/fonts/*.TTC

# Local settings
.claude/settings.local.json

# Internal project files (not for distribution)
data/
!src/scifig/data/
doc/
docs/_build/
.workflow/
CLAUDE.md
